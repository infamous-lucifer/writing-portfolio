---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<?xml-stylesheet type="text/xsl" href="{{ '/sitemap.xsl' | url }}"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all %}
  {%- if not page.data.draft and not page.url contains "posts_trash" %}
  <url>
    <loc>https://infamous-lucifer.github.io/writing-portfolio{{ page.url }}</loc>
    <lastmod>{{ page.date | date: "%Y-%m-%d" }}</lastmod>
    <changefreq>{% if page.data.changefreq %}{{ page.data.changefreq }}{% elsif page.url contains '/posts/' %}never{% elsif page.url == '/writing-portfolio/' or page.url == '/' %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if page.url == '/writing-portfolio/' or page.url == '/' %}1.0{% elsif page.url contains '/writing/' or page.url contains '/work/' or page.url contains '/about/' %}0.8{% elsif page.url contains '/posts/' %}0.7{% else %}0.3{% endif %}</priority>
  </url>
  {%- endif %}
{%- endfor %}
</urlset>
