---
layout: layout.liquid
title: Home
---

<section class="home-manifesto">
  <span class="lbl">Akshat Singh · Writing & Work</span>
  <h1 class="hero-name">
    I write about <em>the things</em><br>
    that don't have easy answers.
  </h1>
  <p class="subhead">
    {{ collections.posts.length }} personal essays on loneliness, ambition, and what it costs 
    to stay honest. Plus professional SEO work across 6 industries.
  </p>
</section>

{% assign _p1 = collections.posts | where: "fileSlug", "case-study-building-this-portfolio" | first %}
{% assign latest_writing = collections.posts | first %}
{% if latest_writing.fileSlug == _p1.fileSlug %}
  {% assign latest_writing = collections.posts[1] %}
{% endif %}

<section class="g3 rev grid-top">

  <article class="post-preview card bento-wide">
    <div class="read-time-pill">{% if _p1 %}{{ _p1.templateContent | readingTime }}{% else %}5 min read{% endif %}</div>
    <div class="c-client">Featured Piece · Personal Blog</div>
    <div class="badge acc">Deep Dive</div>
    <a href="/posts/case-study-building-this-portfolio/" class="c-title c-title-lg">Building a Fast, Privacy-First Portfolio: A Case Study</a>
    <p class="c-desc c-desc-md">An inside look at the architecture, design system, and code optimizations behind this portfolio. From zero-bloat analytics to batched DOM rendering.</p>
  </article>

  <article class="post-preview card" id="dynamic-work-card">
    <div class="read-time-pill" id="dynamic-work-read">Live Sync</div>
    <div class="c-client" id="dynamic-work-client">Latest Professional Work</div>
    <div class="badge grn">Industry</div>
    <a href="/work/" class="c-title" id="dynamic-work-title">Loading latest project...</a>
    <p class="c-desc" id="dynamic-work-desc">Fetching directly from the live database.</p>
  </article>

  <article class="post-preview card card-full" id="dynamic-writing-card">
    <div class="read-time-pill" id="dynamic-writing-read">{% if latest_writing %}{{ latest_writing.templateContent | readingTime }}{% else %}5 min read{% endif %}</div>
    <div class="featured-card-layout">
      <div class="featured-card-content">
        <div class="c-client" id="dynamic-writing-client">Latest Writing · {{ latest_writing.data.category | default: "Personal" }}</div>
        <div class="badge blu block-badge">Newest</div>
        <a href="{{ latest_writing.url }}" class="c-title c-title-md" id="dynamic-writing-title">{{ latest_writing.data.title }}</a>
        <p class="c-desc" id="dynamic-writing-desc">{{ latest_writing.data.description }}</p>
      </div>
      <div class="featured-card-sidebar">
        <div class="sidebar-text">The most recently published piece from the writing collection.</div>
      </div>
    </div>
  </article>

</section>

<script>
  (async function() {
    // Fetch Latest Work
    try {
      const res = await fetch("https://script.google.com/macros/s/AKfycbw1J7-yT2pIRKBXYNqNbKOGe8ZNFqvGTZJXd-yQ1pFmG7Ffg4xsUdcMa4ujax4WF1081g/exec");
      const data = await res.json();
      if (data && data.length > 0) {
        const latest = data[0]; 
        document.getElementById('dynamic-work-read').innerText = "Live";
        document.getElementById('dynamic-work-client').innerText = latest.category || "Professional SEO";
        const titleEl = document.getElementById('dynamic-work-title');
        titleEl.innerText = latest.display_title;
        if (latest.link_url) {
          titleEl.href = latest.link_url;
          titleEl.target = "_blank";
          titleEl.rel = "noopener noreferrer";
        }
        document.getElementById('dynamic-work-desc').innerText = latest.excerpt || "View this piece.";
      }
    } catch (e) {
      console.error("Failed to fetch latest work", e);
      document.getElementById('dynamic-work-title').innerText = "View All Professional Work";
      document.getElementById('dynamic-work-desc').innerText = "Explore the full matrix of SEO content.";
    }

    // Fetch Latest Writing
    try {
      const res = await fetch("/writing-portfolio/posts.json");
      const data = await res.json();
      if (data && data.length > 0) {
        const latest = data[0]; 
        document.getElementById('dynamic-writing-read').innerText = latest.readingTime || "5 min read";
        document.getElementById('dynamic-writing-client').innerText = `Latest Writing · ${latest.category || 'Personal'}`;
        const titleEl = document.getElementById('dynamic-writing-title');
        titleEl.innerText = latest.title;
        titleEl.href = latest.url;
        document.getElementById('dynamic-writing-desc').innerText = latest.description;
      }
    } catch (e) {
      console.error("Failed to fetch latest writing", e);
    }
  })();
</script>

{% include "newsletter.liquid" %}