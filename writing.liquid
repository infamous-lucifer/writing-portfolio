---
layout: layout.liquid
title: Writing Hub
description: "{{ collections.posts.length }} pieces of personal exploration — from introspective essays to long-form prose."
---

<div class="sh grid-top"><span class="sh-lbl">{{ collections.posts.length }} pieces of personal exploration — from introspective essays to algorithm-inspired verses.</span><div class="sh-line"></div></div>

<div class="writing-hero-title">Writing</div>
<div class="fbar">
    <div class="ftabs" role="tablist" aria-label="Writing categories">
        <button class="ftab active" data-f="all" type="button" aria-selected="true" role="tab">All Pieces</button>
        <button class="ftab" data-f="blogs" type="button" aria-selected="false" role="tab">Personal Blogs</button>
        <button class="ftab" data-f="poems" type="button" aria-selected="false" role="tab">Poems</button>
        <button class="ftab" data-f="prose" type="button" aria-selected="false" role="tab">Prose</button>
    </div>
</div>

<div class="g3 rev" id="project-grid">
    {% for post in collections.writingPosts %}
      {% assign slug = post.inputPath | split: "/" | last | replace: ".md", "" %}
      {% assign card = writingCards[slug] %}
      {% assign variant = card.variant | default: "default" %}
      {% assign summary = card.summary | default: post.data.description %}
      <article class="{% if variant == 'featured' %}card-feat post-preview card{% elsif variant == 'compact' %}card-min post-preview card{% else %}card post-preview{% endif %}" data-category="{{ post.data.category | downcase }}">
          <div class="read-time-pill">{{ post.templateContent | readingTime }}</div>
          <div class="c-client">{{ post.data.category | capitalize }} · {{ post.date | date: "%b %Y" }}</div>
          <a href="{{ post.url }}" class="c-title">{{ post.data.title }}</a>
          <p class="c-desc">{{ summary | strip_html }}</p>
          <div class="sr"><a href="{{ post.url }}" class="live-link">Read Full Piece</a></div>
      </article>
    {% endfor %}
</div>
