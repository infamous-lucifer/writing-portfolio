---
layout: layout.liquid
title: Writing Hub · Akshat Singh
description: 60+ pieces of personal exploration — from introspective essays and algorithm-inspired verses to long-form prose about the human condition.
---

<section class="portfolio-hero">
    <div class="container">
        <p class="hero-subtitle">60+ pieces of personal exploration — from introspective essays to algorithm-inspired verses.</p>
    </div>
</section>

<section class="portfolio-grid-section">
    <div class="container">
        <!-- FILTER BAR -->
        <div class="fbar">
            <div class="ftabs">
                <button class="ftab active" data-f="all" type="button" aria-selected="true">All Pieces</button>
                <button class="ftab" data-f="Blogs" type="button" aria-selected="false">Personal Blogs</button>
                <button class="ftab" data-f="Poems" type="button" aria-selected="false">Poems</button>
                <button class="ftab" data-f="Prose" type="button" aria-selected="false">Prose</button>
            </div>
        </div>

        <!-- WRITING GRID -->
        <div class="case-grid" id="project-grid">
            {% for post in collections.posts %}
            <article class="case-card" data-category="{{ post.data.category }}">
                <div class="c-header">
                    <span class="c-client">{{ post.data.category }}</span>
                    <span class="c-date">{{ post.date | date: "%b %Y" }}</span>
                </div>
                <h3 class="c-title">{{ post.data.title }}</h3>
                <p class="c-desc">{{ post.templateContent | excerpt }}</p>
                <div class="c-footer">
                    <a href="{{ post.url | url }}" class="btn-text">Read Full Piece ➔</a>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>
