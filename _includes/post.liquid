---
layout: layout.liquid
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "datePublished": "{{ date | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": {
    "@type": "Person",
    "name": "Akshat Singh"
  },
  "publisher": {
    "@type": "Person",
    "name": "Akshat Singh"
  },
  "description": "{{ content | strip_html | truncate: 160 }}"
}
</script>

<div class="sh"><span class="sh-lbl">{{ category }}</span><div class="sh-line"></div></div>

<div class="g2 rev">
  <article class="card card-full" style="padding-bottom: 60px;">
    <div class="mb-2">
        <h1 class="c-title c-title-lg">{{ title }}</h1>
        <div class="badge acc">{{ date | date: "%B %d, %Y" }}</div>
    </div>
    
    <div class="c-desc c-desc-lg">
      {{ content }}
    </div>

    <div class="sr mt-1" style="border-top: 1px solid var(--border); padding-top: 20px;">
        <a href="{{ '/writing' | url }}" class="live-link">← Back to Writing Hub</a>
    </div>
  </article>
</div>
