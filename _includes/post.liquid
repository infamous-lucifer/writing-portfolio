---
layout: layout.liquid
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "datePublished": "{{ date | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": {
    "@type": "Person",
    "name": "Akshat Singh"
  },
  "publisher": {
    "@type": "Person",
    "name": "Akshat Singh"
  },
  "description": "{{ content | strip_html | truncate: 160 }}"
}
</script>

<style>
  .reader-container {
    max-width: 760px;
    margin: 60px auto 120px;
    animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .post-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .post-category {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--acc);
    margin-bottom: 20px;
    display: block;
  }
  .post-title {
    font-family: var(--f-head);
    font-size: clamp(38px, 5vw, 64px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--txt);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .post-meta {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--txt-3);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .post-content {
    font-family: var(--f-head);
    font-size: 21px;
    line-height: 1.85;
    color: var(--txt-2);
  }
  .post-content p {
    margin-bottom: 32px;
  }
  .post-content strong {
    color: var(--txt);
    font-weight: 600;
  }
  /* Elegant Drop Cap for the first paragraph of content */
  .post-content > p:first-of-type::first-letter {
    font-family: var(--f-head);
    float: left;
    font-size: 5rem;
    line-height: 0.85;
    margin-top: 6px;
    margin-right: 12px;
    font-weight: 700;
    color: var(--acc);
  }
  .post-footer {
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: center;
  }
</style>

<div class="reader-container">
  <header class="post-header">
    <span class="post-category">{{ category }}</span>
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <span>Published on</span>
      <span style="color: var(--txt);">{{ date | date: "%B %d, %Y" }}</span>
    </div>
  </header>
  
  <article class="post-content">
    {{ content }}
  </article>

  <footer class="post-footer">
    <a href="{{ '/writing' | url }}" class="back-link">Back to Writing Hub</a>
  </footer>
</div>
