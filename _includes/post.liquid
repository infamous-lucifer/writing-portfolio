---
layout: layout.liquid
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "datePublished": "{{ date | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{% if lastModified %}{{ lastModified | date: '%Y-%m-%dT%H:%M:%SZ' }}{% else %}{{ date | date: '%Y-%m-%dT%H:%M:%SZ' }}{% endif %}",
  "image": "https://infamous-lucifer.github.io/writing-portfolio/images/hero.jpg",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://infamous-lucifer.github.io/writing-portfolio{{ page.url }}"
  },
  "author": {
    "@type": "Person",
    "name": "Akshat Singh",
    "url": "https://infamous-lucifer.github.io/writing-portfolio/",
    "@id": "https://infamous-lucifer.github.io/writing-portfolio/#person"
  },
  "publisher": {
    "@type": "Person",
    "name": "Akshat Singh",
    "url": "https://infamous-lucifer.github.io/writing-portfolio/",
    "@id": "https://infamous-lucifer.github.io/writing-portfolio/#person"
  },
  "description": "{{ content | strip_html | truncate: 160 }}"
}
</script>

<div class="reader-container">
  <header class="post-header">
    <span class="post-category">{{ category }}</span>
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <span>Published on</span>
      <span style="color: var(--txt);">{{ date | date: "%B %d, %Y" }}</span>
      <span style="color: var(--txt-3);">·</span>
      <span style="color: var(--txt);">{{ content | readingTime }}</span>
    </div>
  </header>

  {% if image %}
  <div class="post-cover-wrapper">
    <img src="{{ image}}" alt="Cover image for {{ title }}" class="post-cover-image">
  </div>
  {% endif %}
  
  <article class="post-content">
    {{ content }}
  </article>

  {% include "newsletter.liquid" %}

  <footer class="post-footer">
    <a href="{{ '/writing/' | url }}" class="card card-min back-card">
      <span class="arrow">←</span>
      <span class="lbl">BACK TO<br>WRITING HUB</span>
    </a>

    <div class="post-footer-more">
      <div class="sh"><span class="sh-lbl">More in {{ category | capitalize }}</span><div class="sh-line"></div></div>
      <div class="g2 related-grid">
        {% assign count = 0 %}
        {% for relPost in collections.posts %}
          {% if relPost.data.category == category and relPost.url != page.url and count < 2 %}
            <a href="{{ relPost.url | url }}" class="card-min post-preview card rel-card">
              <div class="c-client">{{ relPost.data.category | capitalize }} · {{ relPost.date | date: "%b %Y" }}</div>
              <h3 class="c-title">{{ relPost.data.title }}</h3>
            </a>
            {% assign count = count | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </footer>
</div>

<div class="progress-bar"></div>
