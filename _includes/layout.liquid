<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if page.url == "/" or page.url == "/index.html" %}Akshat Singh | Personal Essays, Prose & SEO Content Portfolio{% else %}{% if title %}{{ title }} | {% endif %}Akshat Singh{% endif %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400;500&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" rel="stylesheet" />
    <meta name="view-transition" content="same-origin" />

    <meta name="description" content="{% if description %}{{ description | strip_html | truncate: 160 }}{% else %}Akshat Singh — SEO content writer based in Chandigarh. Extensive published work across ESL, healthcare education, IT, and appellate law.{% endif %}">
    <meta name="keywords" content="SEO content writer, ESL content, healthcare writing, F-1 visa content, IT career writing, Akshat Singh">
    <meta property="og:title" content="{% if page.url == '/' or page.url == '/index.html' %}Akshat Singh | Personal Essays, Prose & SEO Content Portfolio{% elsif title %}{{ title }} | Akshat Singh{% else %}Akshat Singh | Content Portfolio{% endif %}">
    <meta property="og:description" content="{% if description %}{{ description | strip_html | truncate: 160 }}{% else %}SEO content writer — extensive published work across ESL, healthcare education, IT, and appellate law.{% endif %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://infamous-lucifer.github.io/writing-portfolio{{ page.url }}">
    <meta property="og:image" content="{% if image %}{{ image}}{% else %}https://infamous-lucifer.github.io/writing-portfolio/images/hero.jpg{% endif %}">
    <meta property="og:image:alt" content="{% if page.url == '/' or page.url == '/index.html' %}Akshat Singh — Personal Essays, Prose & SEO Content Portfolio{% elsif title %}{{ title }}{% else %}Akshat Singh — Content Portfolio{% endif %}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% if page.url == '/' or page.url == '/index.html' %}Akshat Singh | Personal Essays, Prose & SEO Content Portfolio{% elsif title %}{{ title }} | Akshat Singh{% else %}Akshat Singh | Content Portfolio{% endif %}">
    <meta name="twitter:description" content="{% if description %}{{ description | strip_html | truncate: 160 }}{% else %}SEO content writer — extensive published work across ESL, healthcare education, IT, and appellate law.{% endif %}">
    <meta name="twitter:image" content="{% if image %}{{ image}}{% else %}https://infamous-lucifer.github.io/writing-portfolio/images/hero.jpg{% endif %}">
    <link rel="canonical" href="https://infamous-lucifer.github.io/writing-portfolio{{ page.url }}">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
    <script src="/pagefind/pagefind-ui.js" defer></script>
    <script src="/assets/analytics.js" defer></script>
    <script src="/assets/site.js" defer></script>

    {% if page.url contains '/posts/' %}
      <!-- Specific BlogPosting/Article JSON-LD is loaded inside post.liquid template -->
    {% else %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "dateCreated": "2024-11-15T00:00:00+05:30",
      "dateModified": "2026-06-14T00:00:00+05:30",
      "mainEntity": {
        "@type": "Person",
        "@id": "https://infamous-lucifer.github.io/writing-portfolio/#person",
        "name": "Akshat Singh",
        "alternateName": "bored.aks",
        "url": "https://infamous-lucifer.github.io/writing-portfolio/",
        "jobTitle": "SEO Content Writer",
        "description": "SEO content writer with extensive published work across ESL, healthcare career education, IT, cybersecurity, appellate law, and dive tourism.",
        "image": "https://infamous-lucifer.github.io/writing-portfolio/images/hero.jpg",
        "sameAs": [
          "https://substack.com/@akshat007",
          "https://www.linkedin.com/in/akshat-singh-60695b313/",
          "https://medium.com/@bikshat062",
          "https://github.com/infamous-lucifer",
          "https://www.instagram.com/bored.aks/",
          "https://skillshop.credential.net/profile/akshatsingh666/wallet"
        ],
        "knowsAbout": [
          "SEO Content Writing",
          "ESL & F-1 Immigration Content",
          "Healthcare Career Education Writing",
          "IT & Cybersecurity Writing",
          "Appellate Law Content",
          "Google Business Profile Content",
          "Eleventy Static Site Development",
          "Creative Prose & Personal Essays"
        ]
      }
    }
    </script>
    {% endif %}

    <script>
      (function() {
        const saved = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
</head>
<body data-page="{{ title | downcase }}">

    <div class="topo">
      <svg viewBox="0 0 1400 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <style>
            .tl { fill: none; stroke: var(--acc-l); stroke-width: 1; }
            .tl2 { fill: none; stroke: var(--border); stroke-width: 0.6; }
          </style>
        </defs>
        <g class="topo-grp-1">
          <ellipse class="tl2" cx="180" cy="130" rx="420" ry="260"/><ellipse class="tl" cx="180" cy="130" rx="330" ry="200"/><ellipse class="tl2" cx="180" cy="130" rx="245" ry="148"/><ellipse class="tl" cx="180" cy="130" rx="165" ry="100"/><ellipse class="tl2" cx="180" cy="130" rx="95" ry="58"/><ellipse class="tl" cx="180" cy="130" rx="40" ry="24"/>
        </g>
        <g class="topo-grp-2">
          <ellipse class="tl2" cx="1100" cy="450" rx="500" ry="310"/><ellipse class="tl" cx="1100" cy="450" rx="400" ry="248"/><ellipse class="tl2" cx="1100" cy="450" rx="295" ry="183"/><ellipse class="tl" cx="1100" cy="450" rx="195" ry="122"/><ellipse class="tl2" cx="1100" cy="450" rx="105" ry="65"/><ellipse class="tl" cx="1100" cy="450" rx="42" ry="26"/>
        </g>
      </svg>
    </div>



    <nav>
        <div class="container">
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/work/">Work</a>
                <a href="/writing/">Writing</a>
                <a href="/about/">About</a>
            </div>
            <div class="nav-extra">
                <div id="search" class="search-box"></div>
                <button id="theme-toggle" aria-label="Toggle Theme">
                    <span class="t-icon">☼</span>
                </button>
                <button id="mobile-menu-btn" aria-label="Open Menu">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            {{ content }}
        </div>
    </main>


